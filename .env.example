# ─────────────────────────────────────────────────────────────
#  System Design Studio — environment variables
#  Copy this file to .env and fill in the values.
#  Never commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── AI (required for live generation) ───────────────────────
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Gemini model (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# ── Auth (required) ──────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# ── Frontend (GitHub Pages builds only) ─────────────────────
# Full URL of your Node API, no trailing slash (set in GitHub Actions secret BACKEND_URL too).
# VITE_API_BASE_URL=https://your-api.fly.dev
# Vite asset base for project Pages — CI sets VITE_BASE=/repo-name/ automatically.

# ── Database (required) ─────────────────────────────────────
# Local: createdb system_design_studio
#   postgresql://postgres:postgres@127.0.0.1:5432/system_design_studio
# Hosted: Neon / Supabase — paste the connection string (SSL on by default).
# Local Postgres without SSL: DATABASE_SSL=0
DATABASE_URL=
# DATABASE_SSL=0

# ── Server ───────────────────────────────────────────────────
PORT=4173
NODE_ENV=development

# Loaded automatically from this file via dotenv (see server startup).
# Require sign-in for /api/generate and /api/export (defaults ON when NODE_ENV=production).
# Set to 1 in development to test the same behavior locally.
# REQUIRE_AUTH_GENERATE=1

# Only if the app sits behind a trusted reverse proxy (nginx, etc.):
# TRUST_PROXY=1

# ── CORS (production only) ───────────────────────────────────
# Set to your actual frontend URL in production
# ALLOWED_ORIGIN=https://your-domain.com

# Public URL of the app (no trailing slash) — used in password-reset emails
# APP_PUBLIC_URL=https://your-domain.com
# On Render, RENDER_EXTERNAL_URL is set for you; used for CORS + reset links if APP_PUBLIC_URL is unset.

# ── Password reset email (production) ───────────────────────
# Option A — Resend (https://resend.com)
# RESEND_API_KEY=
# EMAIL_FROM="System Design Studio <onboarding@your-domain.com>"

# Option B — SMTP
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM="System Design Studio <noreply@your-domain.com>"
